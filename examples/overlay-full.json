{
  "gateway": {
    "port": 18891,
    "auth": {
      "mode": "token",
      "token": "omnimem-smoke-token"
    }
  },
  "plugins": {
    "enabled": true,
    "load": {
      "paths": [
        "/ABSOLUTE/PATH/TO/OmniMem-OpenClaw-Plugin/plugins/omnimemory-overlay"
      ]
    },
    "entries": {
      "omnimemory-overlay": {
        "enabled": true,
        "config": {
          "apiKey": "${OMNI_MEMORY_API_KEY}",
          "baseUrl": "https://zdfdulpnyaci.sealoshzh.site/api/v1/memory",
          "recallScope": "global",
          "ingestScope": "session",
          "searchLimit": 8,
          "failSilent": true,
          "timeoutMs": 10000,
          "autoRecall": true,
          "autoCapture": true,
          "recallTopK": 20,
          "recallMinScore": 0,
          "minPromptChars": 8,
          "captureStrategy": "last_turn",
          "captureRoles": ["user"],
          "writeWait": false,
          "promptBlockTitle": "OmniMemory Recall"
        }
      }
    }
  }
}
