{
  "gateway": {
    "port": 18891,
    "auth": {
      "mode": "token",
      "token": "omnimem-smoke-token"
    }
  },
  "plugins": {
    "enabled": true,
    "load": {
      "paths": [
        "/ABSOLUTE/PATH/TO/OmniMem-OpenClaw-Plugin/plugins/omnimemory-memory"
      ]
    },
    "slots": {
      "memory": "omnimemory-memory"
    },
    "entries": {
      "omnimemory-memory": {
        "enabled": true,
        "config": {
          "apiKey": "test-omni-key",
          "baseUrl": "http://127.0.0.1:18890",
          "failSilent": false,
          "autoCapture": false,
          "timeoutMs": 5000
        }
      }
    }
  }
}
